generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Doctor {
  doctor_id      Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  phone          String   @unique
  department     String
  specialization String
  created_at     DateTime @default(now())
}